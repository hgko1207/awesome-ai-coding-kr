---
import {
  getTools,
  getCategories,
  getResources,
  RESOURCE_TYPE_ORDER,
  RESOURCE_TYPE_LABEL,
  link,
  starsLabel,
  STATUS_LABEL,
} from "../lib/data.ts";

const tools = getTools();
const categories = getCategories();
const resources = getResources();
const triedCount = tools.filter((t) => t.tried).length;
const catName = (key: string) => categories.find((c) => c.key === key)?.name ?? key;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>awesome-ai-coding-kr — 직접 써본 AI 코딩 도구 큐레이션</title>
    <meta
      name="description"
      content="직접 써본 AI 코딩 도구를 솔직한 한국어 평과 함께 모은 큐레이션. 양이 아니라 신뢰로 승부합니다."
    />
    <link rel="icon" href={`${base}/favicon.svg`} />
  </head>
  <body>
    <header class="hero">
      <h1>awesome-ai-coding-kr</h1>
      <p class="tagline">직접 써본 AI 코딩 도구를 <strong>솔직한 한국어 평</strong>과 함께. 양이 아니라 신뢰로.</p>
      <p class="stats">
        도구 <b>{tools.length}</b>개 · 직접 검증 <b>{triedCount}</b>개 ·
        <a href="https://github.com/hgko1207/awesome-ai-coding-kr">GitHub ↗</a>
      </p>
      <ul class="legend">
        <li><span>✅ 검증</span> 직접 써보고 평함 (1인칭 경험)</li>
        <li><span>🔥 인기</span> 개발자들 사이에서 널리 쓰임 (일반 평판 · 개인 검증과는 별개)</li>
        <li><span>★ 별점</span> 직접 써본 도구에만 매긴 솔직한 평가</li>
      </ul>
    </header>

    <div class="controls">
      <input id="search" type="search" placeholder="🔍 도구·태그·설명 검색…" autocomplete="off" />
      <div class="filters" id="filters">
        <button class="chip active" data-cat="all">전체 <span class="n">{tools.length}</span></button>
        <button class="chip" data-cat="tried">✅ 직접 검증 <span class="n">{triedCount}</span></button>
        <button class="chip" data-cat="popular">🔥 인기 <span class="n">{tools.filter((t) => t.popular).length}</span></button>
        {
          categories.map((c) => {
            const n = tools.filter((t) => t.category === c.key).length;
            return n ? (
              <button class="chip" data-cat={c.key}>
                {c.name} <span class="n">{n}</span>
              </button>
            ) : null;
          })
        }
      </div>
    </div>

    <main id="grid">
      {
        tools.map((t) => {
          const href = link(t);
          const haystack = [t.name, t.id, t.review.ko.blurb, ...t.tags, catName(t.category)]
            .join(" ")
            .toLowerCase();
          return (
            <article
              class="card"
              data-cat={t.category}
              data-tried={String(t.tried)}
              data-popular={String(!!t.popular)}
              data-search={haystack}
            >
              <div class="card-head">
                <h3>
                  {href ? <a href={href}>{t.name}</a> : t.name}
                  {t.tried && <span class="verified" title="직접 써보고 검증함">✅</span>}
                  {t.popular && <span class="popular" title="널리 쓰이는 대중적 도구">🔥</span>}
                </h3>
                {t.tried && t.rating != null && (
                  <span class="rating" title={`${t.rating}/5`}>
                    {"★".repeat(t.rating)}
                    <span class="dim">{"★".repeat(5 - t.rating)}</span>
                  </span>
                )}
              </div>
              <p class="blurb">{t.review.ko.blurb}</p>
              <div class="meta">
                <span class="cat">{catName(t.category)}</span>
                {t.stars != null && <span class="stars">{starsLabel(t.stars)}</span>}
                {STATUS_LABEL[t.status] && <span class="status">{STATUS_LABEL[t.status]}</span>}
              </div>
              <div class="tags">
                {t.tags.map((tag) => (
                  <span class="tag">#{tag}</span>
                ))}
              </div>
              {t.review.ko.post && (
                <a class="post" href={t.review.ko.post}>
                  📝 심층 리뷰 읽기
                </a>
              )}
            </article>
          );
        })
      }
      <p id="empty" hidden>검색 결과가 없습니다.</p>
    </main>

    {
      resources.length > 0 && (
        <section class="resources">
          <h2>📚 학습 자료 & 가이드</h2>
          <p class="sub">AI 코딩을 잘하기 위한 가이드·문서·아티클. 도구가 아니라 '잘 쓰는 법'.</p>
          {RESOURCE_TYPE_ORDER.map((type) => {
            const inType = resources.filter((r) => r.type === type);
            if (!inType.length) return null;
            return (
              <div class="rgroup">
                <h3>{RESOURCE_TYPE_LABEL[type]}</h3>
                <ul>
                  {inType.map((r) => (
                    <li>
                      <span class="lang">{r.lang === "ko" ? "🇰🇷" : "🇬🇧"}</span>
                      <a href={r.url}>{r.title}</a>
                      {r.tried && <span class="verified" title="직접 읽고 검증함">✅</span>}
                      {r.source && <span class="src">— {r.source}</span>}
                      <span class="rblurb">{r.blurb}</span>
                    </li>
                  ))}
                </ul>
              </div>
            );
          })}
        </section>
      )
    }

    <footer>
      데이터는 <a href="https://github.com/hgko1207/awesome-ai-coding-kr/tree/main/collections"
        >collections/*.yaml</a
      >에서 자동 생성 · 매일 GitHub Actions가 스타·상태 갱신
    </footer>

    <script is:inline>
      const search = document.getElementById("search");
      const cards = [...document.querySelectorAll("#grid .card")];
      const chips = [...document.querySelectorAll(".chip")];
      const empty = document.getElementById("empty");
      let cat = "all";

      function apply() {
        const q = search.value.trim().toLowerCase();
        let shown = 0;
        for (const card of cards) {
          const matchCat =
            cat === "all"
              ? true
              : cat === "tried"
                ? card.dataset.tried === "true"
                : cat === "popular"
                  ? card.dataset.popular === "true"
                  : card.dataset.cat === cat;
          const matchText = !q || card.dataset.search.includes(q);
          const show = matchCat && matchText;
          card.hidden = !show;
          if (show) shown++;
        }
        empty.hidden = shown !== 0;
      }

      search.addEventListener("input", apply);
      for (const chip of chips) {
        chip.addEventListener("click", () => {
          chips.forEach((c) => c.classList.remove("active"));
          chip.classList.add("active");
          cat = chip.dataset.cat;
          apply();
        });
      }
    </script>

    <style is:global>
      :root {
        --bg: #0f1115;
        --card: #181b22;
        --border: #262b36;
        --text: #e6e8ee;
        --dim: #8b93a3;
        --accent: #7aa2ff;
        --green: #46c08a;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, "Segoe UI", "Apple SD Gothic Neo", "Malgun Gothic", system-ui, sans-serif;
        line-height: 1.6;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .hero {
        max-width: 1100px;
        margin: 0 auto;
        padding: 56px 24px 24px;
      }
      .hero h1 { font-size: 2.2rem; margin: 0 0 8px; letter-spacing: -0.02em; }
      .tagline { font-size: 1.1rem; color: var(--dim); margin: 0 0 12px; }
      .tagline strong { color: var(--text); }
      .stats { color: var(--dim); margin: 0; font-size: 0.95rem; }
      .stats b { color: var(--text); }
      .legend { list-style: none; padding: 0; margin: 16px 0 0; display: flex; flex-wrap: wrap; gap: 8px 20px; font-size: 0.85rem; color: var(--dim); }
      .legend li { white-space: nowrap; }
      .legend span { color: var(--text); font-weight: 600; margin-right: 4px; }
      .controls {
        max-width: 1100px;
        margin: 0 auto;
        padding: 8px 24px 24px;
        position: sticky;
        top: 0;
        background: linear-gradient(var(--bg) 70%, transparent);
        z-index: 10;
      }
      #search {
        width: 100%;
        padding: 12px 16px;
        font-size: 1rem;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text);
        margin-bottom: 12px;
      }
      #search:focus { outline: none; border-color: var(--accent); }
      .filters { display: flex; flex-wrap: wrap; gap: 8px; }
      .chip {
        padding: 6px 12px;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 999px;
        color: var(--dim);
        font-size: 0.88rem;
        cursor: pointer;
        transition: all 0.12s;
      }
      .chip:hover { border-color: var(--accent); color: var(--text); }
      .chip.active { background: var(--accent); border-color: var(--accent); color: #0b0d12; font-weight: 600; }
      .chip .n { opacity: 0.6; font-size: 0.8em; }
      main {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 24px 48px;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
        gap: 16px;
      }
      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 18px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        transition: border-color 0.12s, transform 0.12s;
      }
      .card:hover { border-color: var(--accent); transform: translateY(-2px); }
      .card-head { display: flex; justify-content: space-between; align-items: start; gap: 8px; }
      .card h3 { margin: 0; font-size: 1.12rem; }
      .verified { font-size: 0.85rem; margin-left: 4px; }
      .rating { color: var(--green); font-size: 0.9rem; white-space: nowrap; }
      .rating .dim { color: var(--border); }
      .blurb { margin: 0; color: #c3c8d4; font-size: 0.94rem; flex: 1; }
      .meta { display: flex; flex-wrap: wrap; gap: 10px; font-size: 0.82rem; color: var(--dim); }
      .meta .cat { color: var(--accent); }
      .tags { display: flex; flex-wrap: wrap; gap: 6px; }
      .tag { font-size: 0.74rem; color: var(--dim); background: #20242e; padding: 2px 8px; border-radius: 6px; }
      .post { font-size: 0.85rem; }
      #empty { grid-column: 1 / -1; text-align: center; color: var(--dim); padding: 48px; }
      .resources {
        max-width: 1100px;
        margin: 0 auto;
        padding: 16px 24px 48px;
        border-top: 1px solid var(--border);
      }
      .resources h2 { font-size: 1.5rem; margin: 24px 0 4px; }
      .resources .sub { color: var(--dim); margin: 0 0 24px; }
      .rgroup h3 { font-size: 1.05rem; color: var(--accent); margin: 24px 0 8px; }
      .rgroup ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
      .rgroup li { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 12px 14px; }
      .rgroup li a { font-weight: 600; }
      .rgroup .lang { margin-right: 6px; }
      .rgroup .verified { margin-left: 4px; }
      .rgroup .src { color: var(--dim); font-size: 0.85rem; margin-left: 6px; }
      .rgroup .rblurb { display: block; color: #c3c8d4; font-size: 0.9rem; margin-top: 4px; }
      footer {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px;
        border-top: 1px solid var(--border);
        color: var(--dim);
        font-size: 0.85rem;
      }
    </style>
  </body>
</html>
